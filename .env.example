# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- MemeGen → Panel Shaq meme handoff (all optional; prod defaults baked in) ---
# These are VITE_-prefixed, so they're read at BUILD time — set before `npm run build`.

# VITE_PANELHAUS_API_BASE: Origin Panel Shaq calls to consume a handoff token.
# Defaults to https://panelhaus.app when unset.
VITE_PANELHAUS_API_BASE="https://panelhaus.app"

# VITE_MEMEGEN_URL: "Make another meme" link target (back to MemeGen).
# Defaults to https://memegen.panelhaus.app when unset.
VITE_MEMEGEN_URL="https://memegen.panelhaus.app"

# VITE_MEME_ADMIN_SECRET: Unlocks the admin text-zone calibrator + gallery via
# /c/from-meme?admin=<secret>. In a PROD build: set a private value to enable the
# admin tools, or LEAVE IT EMPTY/UNSET to disable them entirely (no public
# fallback). In dev it defaults to "panelshaq-admin" regardless.
VITE_MEME_ADMIN_SECRET=""

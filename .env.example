# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- MemeGen → Panel Haus Mobile meme handoff (all optional; prod defaults baked in) ---
# These are VITE_-prefixed, so they're read at BUILD time — set before `npm run build`.

# PANELHAUS_API_BASE: upstream that BOTH the api/handoff-consume proxy AND the
# shared-credit calls (reserve/refund/balance) hit server-to-server. NOT VITE_-
# prefixed (server-side). Use the non-redirecting origin: https://www.panelhaus.app.
# (The apex panelhaus.app 307-REDIRECTS to www, and the Authorization header is
# STRIPPED on cross-origin redirects, which would 401 the credit calls.) The credit
# routes self-heal: they normalize "://panelhaus.app" -> "://www.panelhaus.app" and
# use redirect:"manual" so any remaining redirect fails loudly instead of dropping auth.
PANELHAUS_API_BASE="https://www.panelhaus.app"

# --- Shared Clerk auth + shared ink credits (panel_shaq <-> Panel Haus) ---
# See documents/CLERK_CREDITS_INTEGRATION_BUILD_PLAN.md. Use the SAME Clerk
# instance as Panel Haus (panelhaus.app) — same publishable key — or the shared
# account breaks.

# VITE_CLERK_PUBLISHABLE_KEY: frontend Clerk SDK key (pk_live_... in prod). VITE_-
# prefixed -> baked at BUILD time. MUST match Panel Haus's instance.
VITE_CLERK_PUBLISHABLE_KEY=""

# CLERK_SECRET_KEY: server-side, used by our api/ routes to verify the Clerk
# Bearer token (@clerk/backend verifyToken). sk_live_... in prod. NEVER VITE_-prefix.
CLERK_SECRET_KEY=""

# Ink charged per image generation (generate-image + final-render), by the model the
# user picks in Settings. Server-side; optional. Match Panel Haus's per-model costs.
INK_COST_IMAGE_FLASH="1"
INK_COST_IMAGE_PRO="2"

# Gemini image models per tier (optional; defaults shown). Flash = cheaper/faster,
# Pro = higher quality — mirror Panel Haus's GEMINI_FLASH_MODEL / GEMINI_PRO_MODEL.
GEMINI_IMAGE_MODEL_FLASH="gemini-2.5-flash-image"
GEMINI_IMAGE_MODEL_PRO="gemini-3.1-flash-image-preview"

# INK_COST_TEXT: ink charged per text/vision AI call (generate-panels, insert-panel,
# polish-story, analyze-character, critique-comic, suggest-dialogue). Server-side;
# optional (default 1). Admins (PH bypass toggle) and BYOK skip the charge.
INK_COST_TEXT="1"

# VITE_MEMEGEN_URL: "Make another meme" link target (back to MemeGen).
# Defaults to https://memegen.panelhaus.app when unset.
VITE_MEMEGEN_URL="https://memegen.panelhaus.app"

# VITE_MEME_ADMIN_SECRET: Unlocks the admin text-zone calibrator + gallery via
# /c/from-meme?admin=<secret>. In a PROD build: set a private value to enable the
# admin tools, or LEAVE IT EMPTY/UNSET to disable them entirely (no public
# fallback). In dev it defaults to "panelshaq-admin" regardless.
VITE_MEME_ADMIN_SECRET=""
